{
  "rules": {
    "adminUsers": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["email", "active"]
    },
    "adminLogs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp", "action", "adminId"]
    },
    "systemSettings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "allowRegistration": {
        ".read": true
      }
    },
    "maintenanceMode": {
      ".read": true,
      ".write": "auth != null"
    },
    "announcements": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "emailQueue": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      ".read": "auth != null && (auth.token.email === 'nandheswara21@gmail.com' || root.child('users/' + auth.uid + '/role').val() === 'admin')",
      ".write": "auth != null && (auth.token.email === 'nandheswara21@gmail.com' || root.child('users/' + auth.uid + '/role').val() === 'admin')",
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid",
        "stocks": {
          "$stockId": {
            ".validate": "newData.hasChildren(['symbol', 'name']) && newData.child('symbol').isString() && newData.child('name').isString()",
            ".indexOn": ["symbol", "name", "createdAt", "sector"]
          }
        },
        "portfolio": {
          "$stockId": {
            ".validate": "newData.hasChildren(['name', 'quantity', 'buyPrice', 'totalCost', 'dateAdded']) && newData.child('name').isString() && newData.child('quantity').isNumber() && newData.child('quantity').val() > 0 && newData.child('buyPrice').isNumber() && newData.child('buyPrice').val() >= 0 && newData.child('totalCost').isNumber()",
            ".indexOn": ["name", "dateAdded", "lastModified", "profitLoss"]
          }
        },
        "profile": {
          ".validate": "newData.hasChild('email')"
        },
        "phoneNumber": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "role": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString()"
        },
        "email": {
          ".validate": "newData.isString()"
        },
        "displayName": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "lastActive": {
          ".validate": "newData.isNumber()"
        },
        "metadata": {
          ".validate": true
        },
        "finance": {
          "categories": {
            "$categoryId": {
              ".validate": "newData.hasChild('name') && newData.child('name').isString()",
              "items": {
                "$itemId": {
                  ".validate": "newData.hasChildren(['name', 'amount', 'month']) && newData.child('name').isString() && newData.child('amount').isNumber() && newData.child('month').isString()"
                }
              }
            }
          },
          "banks": {
            "$bankId": {
              ".validate": "newData.hasChild('name') && newData.child('name').isString()"
            }
          },
          "creditCards": {
            "$cardId": {
              ".validate": "newData.hasChild('name') && newData.child('name').isString()"
            }
          },
          "income": {
            "$month": {
              ".validate": "newData.hasChildren(['salary', 'totalIncome']) && newData.child('salary').isNumber() && newData.child('totalIncome').isNumber()"
            }
          },
          "monthlySnapshots": {
            "$month": {
              ".validate": "newData.hasChild('timestamp') && newData.child('timestamp').isNumber()"
            }
          }
        }
      }
    },
    "stocks": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "$userId === auth.uid"
      }
    },
    "portfolio": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "$userId === auth.uid"
      }
    }
  }
}
